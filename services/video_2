async def generate_video_for_product(
    product_id: int,
    req,
    product_image: UploadFile,
) -> Path:
    """
    main.py에서 호출하는 비디오 생성 서비스 함수.
    App.py의 최신 로직(Gemini Multimodal + KIE Sora 2)을 적용.
    """

    # -----------------------------------------
    # 0) Env check
    # -----------------------------------------
    GEMINI_KEY = os.environ.get("gemini_api_key", "")
    KIE_API_KEY = os.environ.get("KIE_API_KEY", "")

    if not GEMINI_KEY:
        raise HTTPException(status_code=500, detail="missing env: gemini_api_key")
    if not KIE_API_KEY:
        raise HTTPException(status_code=500, detail="missing env: KIE_API_KEY")

    os.environ["KIE_API_KEY"] = KIE_API_KEY
    gclient = genai.Client(api_key=GEMINI_KEY)

    # -----------------------------------------
    # 1) Output dir 결정
    # -----------------------------------------
    product_dir = _ensure_product_dir(product_id)
    out_dir = product_dir

    # -----------------------------------------
    # 2) Save uploaded image
    # -----------------------------------------
    img_bytes = await product_image.read()
    if not img_bytes:
        raise HTTPException(status_code=400, detail="empty product_image")

    filename = product_image.filename or "product.png"
    suffix = Path(filename).suffix.lower()
    if suffix not in [".png", ".jpg", ".jpeg", ".webp"]:
        suffix = ".png"

    product_img_path = out_dir / f"product{suffix}"
    product_img_path.write_bytes(img_bytes)

    ref_mime = mimetypes.guess_type(str(product_img_path))[0] or "image/png"
    ref_bytes = img_bytes

    # -----------------------------------------
    # 3) Gemini: Create plan JSON (30초 버전)
    # -----------------------------------------
    SYSTEM = """너는 숏츠 광고 감독이다.
목표: 총 30초 길이의 숏츠 광고를 3개의 씬으로 구성한다. (각 씬 10초)
핵심: 3개의 씬이 '하나의 영상'처럼 자연스럽게 연결되어야 하며, 등장인물과 제품이 100% 동일해야 한다.

[광고 스토리 구성 - 30초 로드맵]
Scene 1 (0-10초): 도입 (Hook) - 제품의 매력적인 등장. 로고와 패키지가 선명하게 보여야 함.
Scene 2 (10-20초): 전개 (Experience) - 사람이 제품을 즐기는 모습. (먹방/음용/사용) 행복한 표정. Scene 1의 제품과 동일해야 함.
Scene 3 (20-30초): 결말 (End) - 여운이 남는 마무리. 제품 클로즈업 + 페이드아웃 느낌.

[필수]
- 인물 묘사: '20대 한국 여성, 긴 생머리, 흰 티셔츠' 처럼 구체적으로 정해서 모든 씬에 일관되게 적용해라.
- 제품 묘사: '빨간색 봉지 라면', '파란색 캔 음료' 등 패키지 특징을 모든 씬에 동일하게 묘사해라.
"""

    plan_prompt = f"""
[제품 정보]
- 식품이름: {req.food_name}
- 식품종류: {req.food_type}
- 광고 컨셉: {req.ad_concept}
- 광고 요구사항: {req.ad_req}

[출력 형식]
JSON으로만 출력해.
{{
  "character_description": "씬 1, 2, 3에 공통으로 등장할 인물의 외모/의상/스타일 묘사 (영어)",
  "contents_description": "제품 내용물(음식)의 시각적 묘사 (색상, 질감, 모양) (영어)",
  "scenes": [
    {{
      "scene_number": 1,
      "duration_hint_sec": 10,
      "scene_script": "한글 스크립트",
      "nano_image_prompt": "이미지 생성 프롬프트 (영어)",
      "video_prompt": "영상 생성 프롬프트 (영어)"
    }},
    ...
  ]
}}
"""

    try:
        resp = gclient.models.generate_content(
            model="gemini-2.5-flash",
            contents=[types.Content(role="user", parts=[types.Part(text=SYSTEM + "\n\n" + plan_prompt)])],
            config=types.GenerateContentConfig(response_mime_type="application/json"),
        )
        plan = json.loads(resp.text)
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"gemini plan generation failed: {e}")

    (out_dir / "video_plan.json").write_text(json.dumps(plan, ensure_ascii=False, indent=2), encoding="utf-8")

    try:
        scenes_list = _normalize_scenes_list(plan)
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"invalid plan json: {e}")

    # 공통 묘사 추출
    char_desc = plan.get("character_description", "")
    cont_desc = plan.get("contents_description", "")
    common_desc = f"Character: {char_desc} | Contents: {cont_desc}" if char_desc or cont_desc else ""

    # -----------------------------------------
    # 4) Gemini: Generate scene images (Multimodal Chain)
    # -----------------------------------------
    STRICT_IMAGE_RULES = """
[CRITICAL PRIORITY: PRODUCT TEXT & LOGO]
1. The FIRST image provided is the PRODUCT REFERENCE. The product package text and logo must be IDENTICAL.
2. Do NOT blur, mistype, or scramble the text. It must be READABLE and SHARP.
3. If the product is held or eaten, the package design must remain consistent.

[Consistency Rule: CHARACTER]
The second image provided (if any) is the REFERENCE FOR THE CHARACTER.
- Use the person from the second image (same face, hair, clothes).
- BUT DO NOT let the character reference degrade the product quality.
""".strip()

    img_paths: List[str] = []
    
    # 이전 씬 이미지 (캐릭터 일관성 유지용)
    previous_scene_img_bytes = None

    for idx, sc in enumerate(scenes_list):
        sid = _get_scene_id(sc, fallback=idx + 1)
        
        # 기본 프롬프트 + 공통 묘사
        base_prompt = sc["nano_image_prompt"].strip()
        if common_desc:
            base_prompt = f"[{common_desc}]\n{base_prompt}"
            
        content_parts = []
        
        # 1. 프롬프트 텍스트
        prompt_text = base_prompt
        
        # 2. 멀티모달 입력 구성
        # 2-1. 제품 이미지 (항상 첫 번째)
        content_parts.append(types.Part.from_bytes(data=ref_bytes, mime_type=ref_mime))
        
        # 2-2. 이전 씬 이미지 (있으면 두 번째 - 캐릭터 참조용)
        if previous_scene_img_bytes:
            content_parts.append(types.Part.from_bytes(data=previous_scene_img_bytes, mime_type="image/png"))
            prompt_text += "\n\n[Reference Info]:\n- Image 1: PRODUCT (Logo/Text must match exactly).\n- Image 2: CHARACTER (Face/Style must match exactly)."
        else:
            prompt_text += "\n\n[Reference Info]: Image 1 is the PRODUCT reference."

        # 최종 프롬프트
        final_prompt = prompt_text + "\n\n" + STRICT_IMAGE_RULES

        content_parts.insert(0, types.Part(text=final_prompt)) # 텍스트를 맨 앞에

        # API 호출 (재시도 로직 포함)
        out_bytes = None
        for attempt in range(3):
            try:
                img_resp = gclient.models.generate_content(
                    model="gemini-2.5-flash-image",
                    contents=[types.Content(role="user", parts=content_parts)],
                    config=types.GenerateContentConfig(response_modalities=["IMAGE"]),
                )
                
                for p in img_resp.candidates[0].content.parts:
                    if getattr(p, "inline_data", None) and p.inline_data.mime_type.startswith("image/"):
                        out_bytes = p.inline_data.data
                        break
                
                if out_bytes: break
            except Exception as e:
                print(f"Scene {sid} generation attempt {attempt+1} failed: {e}")
                await asyncio.sleep(2)
        
        if out_bytes is None:
            raise HTTPException(status_code=500, detail=f"gemini image generation failed after 3 attempts (scene {sid})")

        out_path = out_dir / f"scene_{sid:02d}.png"
        Image.open(io.BytesIO(out_bytes)).save(out_path)
        img_paths.append(str(out_path))
        
        # 다음 씬을 위해 현재 이미지를 저장 (Scene 1만 저장하여 Scene 2, 3의 기준점으로 사용)
        if idx == 0:
            previous_scene_img_bytes = out_bytes

    # -----------------------------------------
    # 5) KIE Sora 2: Generate scene videos (Async Polling)
    # -----------------------------------------
    STRICT_VIDEO_RULES = """
[CRITICAL VIDEO RULES]
1. FACE CONSISTENCY: Keep the person's face (eyes, nose, mouth) IDENTICAL to the source image. Do not morph features.
2. PRODUCT INTEGRITY: Text & Logo on the package must remain READABLE and SHARP. Do not distort.
3. MOVEMENT: Natural, high-quality cinematic motion.
""".strip()

    video_paths: List[str] = []
    
    for idx, sc in enumerate(scenes_list):
        sid = _get_scene_id(sc, fallback=idx + 1)
        duration = sc.get("duration_hint_sec", 10)
        
        base_vid_prompt = sc["video_prompt"].strip()
        if common_desc:
            base_vid_prompt = f"[{common_desc}]\n{base_vid_prompt}"
            
        prompt_vid = (base_vid_prompt + "\n\n" + STRICT_VIDEO_RULES).strip()
        
        try:
            # KIE API 호출 (Polling 포함)
            video_url = await _kie_generate_video(
                kie_key=KIE_API_KEY,
                img_path=img_paths[idx],
                prompt=prompt_vid,
                duration=duration,
                aspect_ratio="9:16"
            )
            
            if not video_url:
                raise ValueError("No video URL returned")

            out_path = out_dir / f"scene_{sid:02d}.mp4"
            _download(video_url, out_path)
            video_paths.append(str(out_path))

        except Exception as e:
            raise HTTPException(status_code=500, detail=f"kie video generation failed (scene {sid}): {e}")

    # -----------------------------------------
    # 6) FFmpeg: concat with xfade -> final video.mp4
    # -----------------------------------------
    final_mp4 = out_dir / "video.mp4"
    try:
        _concat_with_xfade(video_paths, str(final_mp4), fade=0.5)
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"concat failed: {e}")

    return final_mp4
