def _download(url: str, out_path: Path) -> Path:
    r = requests.get(url, stream=True, timeout=600)
    r.raise_for_status()
    with open(out_path, "wb") as f:
        for chunk in r.iter_content(chunk_size=1024 * 1024):
            if chunk:
                f.write(chunk)
    return out_path


def _ffprobe_duration(path: str) -> float:
    cmd = [
        "ffprobe",
        "-v",
        "error",
        "-select_streams",
        "v:0",
        "-show_entries",
        "format=duration",
        "-of",
        "default=noprint_wrappers=1:nokey=1",
        path,
    ]
    out = subprocess.check_output(cmd).decode().strip()
    return float(out)


def _concat_with_xfade(video_paths: List[str], out_path: str, fade: float = 0.5) -> str:
    """
    variable length videos -> xfade chain.
    """
    if len(video_paths) == 1:
        shutil.copyfile(video_paths[0], out_path)
        return out_path

    durs = [_ffprobe_duration(v) for v in video_paths]

    cmd = ["ffmpeg", "-y"]
    for v in video_paths:
        cmd += ["-i", v]

    filters = []
    offset = durs[0] - fade
    filters.append(
        f"[0:v][1:v]xfade=transition=fade:duration={fade}:offset={offset}[v01]"
    )

    total = durs[0] + durs[1]
    prev_label = "v01"

    for i in range(2, len(video_paths)):
        offset = total - fade * (i)
        filters.append(
            f"[{prev_label}][{i}:v]xfade=transition=fade:duration={fade}:offset={offset}[v0{i}]"
        )
        prev_label = f"v0{i}"
        total += durs[i]

    filter_complex = ";".join(filters)

    cmd += [
        "-filter_complex",
        filter_complex,
        "-map",
        f"[{prev_label}]",
        "-r",
        "30",
        "-pix_fmt",
        "yuv420p",
        out_path,
    ]

    subprocess.check_call(cmd)
    return out_path


def _normalize_scenes_list(plan: Any) -> List[Dict[str, Any]]:
    """
    Gemini 응답이 조금씩 흔들릴 수 있어서 안전하게 scenes list를 추출.
    """
    if isinstance(plan, dict):
        if "scenes" in plan and isinstance(plan["scenes"], list):
            return plan["scenes"]
        if "ad_plan" in plan and isinstance(plan["ad_plan"], list):
            return plan["ad_plan"]
        if all(k in plan for k in ["nano_image_prompt", "video_prompt"]):
            return [plan]
        # fallback: try to find any key that is a list
        for k, v in plan.items():
            if isinstance(v, list) and len(v) > 0 and isinstance(v[0], dict):
                return v
        raise ValueError("Unexpected plan json structure (missing scenes/ad_plan).")
    if isinstance(plan, list):
        return plan
    raise ValueError("Unexpected plan type")


def _get_scene_id(scene: Dict[str, Any], fallback: int) -> int:
    sid = scene.get("scene_number") or scene.get("id") or fallback
    try:
        return int(sid)
    except Exception:
        return fallback


async def _kie_generate_video(
    kie_key: str,
    img_path: str,
    prompt: str,
    duration: int = 10,
    aspect_ratio: str = "9:16"
) -> str:
    """KIE Sora 2 API를 사용하여 비디오 생성 (Polling 방식)"""
    
    # 이미지 base64 인코딩
    with open(img_path, "rb") as f:
        img_base64 = base64.b64encode(f.read()).decode("utf-8")
        
    url = "https://api.kie.ai/v1/chat/completions"
    headers = {
        "Authorization": f"Bearer {kie_key}",
        "Content-Type": "application/json"
    }
    
    payload = {
        "model": "sora-2-image-to-video-stable",
        "messages": [
            {
                "role": "user",
                "content": [
                    {
                        "type": "image_url",
                        "image_url": {
                            "url": f"data:image/png;base64,{img_base64}"
                        }
                    },
                    {
                        "type": "text",
                        "text": prompt
                    }
                ]
            }
        ],
        "aspect_ratio": aspect_ratio,
        "duration": duration,
        "loop": False
    }

    # 1. 요청 전송
    try:
        resp = requests.post(url, headers=headers, json=payload, timeout=60)
        resp.raise_for_status()
        data = resp.json()
        
        # request_id 추출 (응답 구조에 따라 다를 수 있음, video_url이 바로 올 수도 있고 id가 올 수도 있음)
        # KIE API는 보통 비동기 처리 후 id를 반환하거나, 바로 url을 반환할 수 있음.
        # 여기서는 app.py의 경험(id 반환 후 polling)을 따름.
        
        request_id = data.get("id")
        if not request_id:
             # 바로 결과가 온 경우 (동기 처리된 경우)
             if "choices" in data and len(data["choices"]) > 0:
                 content = data["choices"][0]["message"]["content"]
                 try:
                     res_json = json.loads(content)
                     return res_json.get("video_url") or res_json.get("url")
                 except:
                     return content # URL string
             # 다른 필드 확인
             if "video_url" in data: return data["video_url"]
             if "url" in data: return data["url"]
             
             raise ValueError(f"No request_id or video_url in response: {data}")
             
    except Exception as e:
        raise RuntimeError(f"KIE API request failed: {e}")

    # 2. Polling
    poll_url = f"https://api.kie.ai/v1/request/{request_id}"
    for _ in range(60): # 최대 5분 대기 (5s * 60)
        await asyncio.sleep(5)
        try:
            p_resp = requests.get(poll_url, headers=headers, timeout=30)
            if p_resp.status_code != 200:
                print(f"Polling status {p_resp.status_code}, retrying...")
                continue
                
            p_data = p_resp.json()
            status = p_data.get("status")
            
            if status == "completed":
                return p_data.get("video_url") or p_data.get("result", {}).get("video_url")
            elif status == "failed":
                raise RuntimeError(f"Video generation failed: {p_data.get('error')}")
            
            # running or pending, continue waiting
            
        except Exception as e:
            print(f"Polling error: {e}")
            continue

    raise RuntimeError("Video generation timed out.")


